# Shell scripts must stay LF so they execute on Linux CI. A stored CRLF in a
# shebang line breaks `bash` / `env` on the GitHub Actions runners. The DR-058
# engine-sync gate runs scripts/*.sh in CI, so this is load-bearing.
*.sh text eol=lf

# Engine-sync fingerprint: keep LF so the committed blob is identical across
# Windows and Linux and the CI manifest diff stays clean.
/scripts/engine-sync.manifest text eol=lf

# Node CLI scripts under scripts/ start with a `#!/usr/bin/env node` shebang,
# which is only valid at byte 0 of a module. On a CRLF checkout (Windows,
# core.autocrlf=true) vitest's vite-node SSR transform fails to strip the
# shebang and leaves it mid-module, so Node rejects it (SyntaxError: Invalid
# or unexpected token) whenever a test imports one of these scripts (e.g.
# publishing-bind-heroes-cli.test.ts importing scripts/publishing-bind-heroes.mjs).
# The blobs are already LF; pinning eol=lf overrides autocrlf so the working
# tree stays LF too. Same load-bearing reason as the *.sh rule above.
*.mjs text eol=lf

# Python operator scripts under scripts/ also start with a `#!/usr/bin/env
# python3` shebang; same load-bearing reason as *.sh and *.mjs above. Only
# two files match today (create-ghl-email-templates.py, qa-verify-templates.py).
*.py text eol=lf

# supabase/run-migrations.js is the one remaining shebang script not covered
# by the *.mjs rule (it is plain .js, not .mjs). Not currently imported by
# any test or invoked in CI, but pinned proactively so it can never regress
# into the same class of bug as *.mjs above if that changes.
/supabase/run-migrations.js text eol=lf
